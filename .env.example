# ============================================
# IBM Bob AI API Configuration
# ============================================
BOB_AI_API_KEY=your_bob_api_key_here
BOB_AI_API_URL=https://api.dataplatform.cloud.ibm.com/semantic_agents/public/v1/mcp_server/mcp/

# ============================================
# Application Configuration
# ============================================
ENVIRONMENT=production
LOG_LEVEL=INFO

# ============================================
# Security Configuration
# ============================================
# IMPORTANT: Change this in production!
SECRET_KEY=your-secret-key-change-in-production-use-strong-random-string

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost,http://localhost:80

# ============================================
# Optional: GitHub Integration
# ============================================
# GITHUB_TOKEN=your_github_personal_access_token_here